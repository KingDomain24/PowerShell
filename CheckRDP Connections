# Getting server list from zstats
# Here I borrowed Danny's query that he wrote to run "QWINSTA.EXE /SERVER:". Thank you Danny.
$query = @'
SELECT 
CASE When DomainName is not NULL then ClusterNodeName+'.'+DomainName
                                 ELSE ClusterNodeName
END AS SERVER
from zsqdbastats.dbo.dbacluster c
   , zsqdbastats.dbo.dbaclusternode n
   , zsqdbastats.dbo.ActiveSQLServer_v s
where c.clustername = n.clustername 
and c.ExcludeInd is null
and c.ClusterName = s.ClusterName
UNION 
SELECT 
CASE When DomainName is not NULL then ServerName+'.'+DomainName
                                 ELSE ServerName
END AS SERVER
from zsqdbastats.dbo.ActiveSQLServer_v  
WHERE (clusterName is NULL or clusterName = '')
order by 1
'@

